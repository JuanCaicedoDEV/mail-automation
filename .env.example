# Database Configuration
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=content_db
DATABASE_URL=postgresql://user:password@localhost:5433/content_db

# AI Configuration
GEMINI_API_KEY=

# Security
# Generate a secure key for authentication
API_SECRET_KEY=dev-secret-key-123
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000

# Email Service (Zoho)
# Use an App Password if using 2FA, or enable "Less secure apps" (not recommended)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=http://127.0.0.1:8000/auth/zoho/callback
ZOHO_EMAIL=
ZOHO_REFRESH_TOKEN=

# Deployment / Public Access
# Set this to your public URL (e.g. ngrok) so images work in real emails
# API_URL=https://your-public-url.ngrok-free.app
API_URL=http://localhost:8000

# Storage Provider: local or supabase
STORAGE_PROVIDER=local